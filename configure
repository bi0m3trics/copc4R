#!/bin/sh
# configure  –  detect libcurl and set COPC4R_WITH_CURL

echo "* Checking for libcurl..."

# Try pkg-config first
CURL_CPPFLAGS=""
CURL_LIBS=""
HAS_CURL="no"

if command -v pkg-config >/dev/null 2>&1; then
    if pkg-config --exists libcurl 2>/dev/null; then
        CURL_CPPFLAGS=$(pkg-config --cflags libcurl)
        CURL_LIBS=$(pkg-config --libs libcurl)
        HAS_CURL="yes"
    fi
fi

# Fallback: try curl-config
if [ "$HAS_CURL" = "no" ] && command -v curl-config >/dev/null 2>&1; then
    CURL_CPPFLAGS=$(curl-config --cflags)
    CURL_LIBS=$(curl-config --libs)
    HAS_CURL="yes"
fi

if [ "$HAS_CURL" = "yes" ]; then
    echo "  Found libcurl. HTTP range-read support enabled."
    CURL_CPPFLAGS="$CURL_CPPFLAGS -DCOPC4R_WITH_CURL"
else
    echo "  libcurl not found. Compiling without HTTP support."
    echo "  Install libcurl-dev to enable reading from URLs."
    CURL_CPPFLAGS=""
    CURL_LIBS=""
fi

# Write to src/Makevars (append curl flags)
sed \
    -e "s|@CURL_CPPFLAGS@|${CURL_CPPFLAGS}|g" \
    -e "s|@CURL_LIBS@|${CURL_LIBS}|g" \
    src/Makevars.in > src/Makevars

echo "* Configuration complete."
